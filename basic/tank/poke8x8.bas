0 'POKE8X8.BAS
10 PMODE 4,1:PCLS:SCREEN 1,1
15 S=PEEK(186)*256+PEEK(187)
16 E=S+6144-1
20 'SET TO START OF GRAPHICS
30 L=S:D=1:GOSUB 1000
40 ON INSTR("*WSAD",INKEY$) GOTO 40,100,200,300,400

100 'UP
110 NL=L-256:D=1:GOTO 500
120 GOTO 40

200 'DOWN
210 NL=L+256:D=2:GOTO 500
220 GOTO 40

300 'LEFT
310 NL=L-1:D=3:GOTO 500
320 GOTO 40

400 'RIGHT
410 NL=L+1:D=4:GOTO 500
420 GOTO 40

500 IF NL=L THEN 40
510 IF NL<S THEN NL=NL+32:GOTO 501
520 IF NL>E THEN NL=NL-32:GOTO 502
530 GOSUB 5000:L=NL:ON D GOSUB 1000,2000,3000,4000
540 GOTO 40

999 GOTO 999

1000 'TANK UP
1010 POKEL,24:POKEL+32,24:POKEL+64,219:POKEL+96,255:POKEL+128,255:POKEL+160,255:POKEL+192,255:POKEL+224,195:RETURN
2000 'TANK DOWN
2010 POKEL,195:POKEL+32,255:POKEL+64,255:POKEL+96,255:POKEL+128,255:POKEL+160,219:POKEL+192,24:POKEL+224,24:RETURN
3000 'TANK LEFT
3010 POKEL,63:POKEL+32,63:POKEL+64,30:POKEL+96,254:POKEL+128,254:POKEL+160,30:POKEL+192,63:POKEL+224,63:RETURN
4000 'TANK RIGHT
4010 POKEL,252:POKEL+32,252:POKEL+64,120:POKEL+96,127:POKEL+128,127:POKEL+160,120:POKEL+192,252:POKEL+224,252:RETURN
5000 'BLANK
5010 POKEL,0:POKEL+32,0:POKEL+64,0:POKEL+96,0:POKEL+128,0:POKEL+160,0:POKEL+192,0:POKEL+224,0:RETURN
